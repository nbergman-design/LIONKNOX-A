# .env.example — copy to .env.local and fill in values

# PostgreSQL connection string
# Local dev:  postgresql://postgres:password@localhost:5432/deal_pipeline
# Neon:       postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/deal_pipeline?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/deal_pipeline"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
